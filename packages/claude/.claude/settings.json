{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "List(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Search(*)",
      "WebSearch",
      "WebFetch(domain:*)",
      "Fetch(https://*)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(mv *)",
      "Bash(make *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(sort *)",
      "Bash(say *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(which *)",
      "Bash(pwd *)",
      "Bash(export *)",
      "Bash(source *)",
      "Bash(ln *)",
      "Bash(touch *)",
      "Bash(file *)",
      "Bash(diff *)",
      "Bash(brew *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pip *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go fmt *)",
      "Bash(go vet *)",
      "Bash(go mod *)",
      "Bash(go list *)",
      "Bash(gofmt *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr create *)",
      "Bash(gh issue create *)",
      "Bash(gh issue edit *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue list *)",
      "Bash(gh issue comment *)",
      "Bash(gh search issues *)",
      "Bash(gh search prs *)",
      "Bash(gh list *)",
      "Bash(gh api *)",
      "Bash(gh label *)",
      "Bash(gh project *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git push *)",
      "Bash(git remote set-url *)",
      "Bash(git pull *)",
      "Bash(git reset *)",
      "Bash(git commit *)",
      "Bash(git cherry-pick *)",
      "Bash(git diff *)",
      "Bash(claude-diff *)",
      "mcp__notionApi__API-post-search",
      "Bash(ssh a1yama-pj *)",
      "mcp__notionApi__API-post-database-query",
      "mcp__notionApi__API-get-block-children",
      "mcp__notionApi__API-retrieve-a-database",
      "mcp__codex"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/packages/claude/.claude/hooks/bash-tool-nudge.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/packages/claude/.claude/hooks/post-edit-check.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-notify"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/packages/claude/.claude/hooks/stop-dispatch.sh",
            "timeout": 180
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/packages/claude/.claude/hooks/settings-drift-check.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -n --arg d \"$(date '+%Y-%m-%d (%a) %H:%M JST')\" '{hookSpecificOutput:{hookEventName:\"UserPromptSubmit\",additionalContext:(\"現在日時: \"+$d)}}'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup /Users/a1yama/ghq/github.com/a1yama/claude-activity-dashboard/scripts/auto-sync.sh >/dev/null 2>&1 &"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/dotfiles/packages/claude/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "codex@openai-codex": true,
    "linear@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true
}
