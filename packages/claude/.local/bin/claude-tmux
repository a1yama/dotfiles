#!/usr/bin/env bash
set -euo pipefail

AGENT_PREFIX="🤖"
AGENTS_DIR="/tmp/claude-agents"
SKILL_DIR="$HOME/.claude/skills/code-review"

usage() {
  cat <<'EOF'
claude-tmux - tmux × Claude Code 並列エージェント管理（オーケストレーション対応）

Usage:
  claude-tmux spawn "タスク説明"  [--name NAME] [--dir DIR] [--no-review]
  claude-tmux issues 42 43 44
  claude-tmux status
  claude-tmux supervise
  claude-tmux questions
  claude-tmux answer <name> <回答>
  claude-tmux logs <name>
  claude-tmux kill [name|all]
  claude-tmux clean

Subcommands:
  spawn      新しいtmuxウィンドウで監督+作業者ペインを起動（実装後に自動レビュー）
  issues     複数のGitHub Issueを並列エージェントで処理
  status     実行中のエージェント一覧とペイン生存確認
  supervise  監督モード：質問待ちエージェントを検出して対話的に回答（推奨）
  questions  質問待ちのエージェント一覧を表示（デバッグ用）
  answer     質問に回答（answerファイル作成 + ペインに通知）（デバッグ用）
  logs       特定エージェントのログを less で表示
  kill       エージェントペイン停止とディレクトリ削除
  clean      完了/死亡したエージェントのディレクトリをクリーンアップ

Note:
  エージェントはインタラクティブモードでペイン分割実行されます。
  質問は監督モード (supervise) が自動的に検出して処理します。
  意図しないファイル変更のリスクがあるため、実行後に git diff で変更内容を確認してください。
EOF
}

require_tmux() {
  if [[ -z "${TMUX:-}" ]]; then
    echo "Error: tmuxセッション内で実行してください" >&2
    exit 1
  fi
}

ensure_agents_dir() {
  mkdir -p "$AGENTS_DIR"
}

get_agent_dir() {
  local name="$1"
  echo "${AGENTS_DIR}/${name}"
}

is_pane_alive() {
  local pane_id="$1"
  tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -q "^${pane_id}$"
}

# spawn: 新しいtmuxウィンドウで監督+作業者ペインを起動
cmd_spawn() {
  require_tmux
  ensure_agents_dir

  local name=""
  local dir=""
  local prompt=""
  local no_review="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        name="$2"
        shift 2
        ;;
      --dir)
        dir="$2"
        shift 2
        ;;
      --no-review)
        no_review="true"
        shift
        ;;
      *)
        if [[ -z "$prompt" ]]; then
          prompt="$1"
        else
          prompt="$prompt $1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$prompt" ]]; then
    echo "Error: タスク説明を指定してください" >&2
    echo "Usage: claude-tmux spawn \"タスク説明\" [--name NAME] [--dir DIR]" >&2
    exit 1
  fi

  if [[ -z "$name" ]]; then
    name="agent-$(date +%s)"
  fi

  local work_dir="${dir:-$(pwd)}"
  local agent_dir="$(get_agent_dir "$name")"

  # エージェントディレクトリ作成
  mkdir -p "$agent_dir"

  # プロンプトファイル作成
  local prompt_file="${agent_dir}/prompt"
  printf '%s' "$prompt" > "$prompt_file"

  # 拡張プロンプト作成
  local enhanced_prompt="${prompt}

---

【重要】自律的な実装について：

このタスクは自動実行モードで実行されています。以下のルールに従ってください：
- ユーザーに質問せず、最善の判断で実装を進めてください
- 技術選択が必要な場合は、一般的でメンテナンス性の高い選択を優先してください
- セキュリティとシンプルさを重視してください

【実装完了後のレビューループ】$(if [[ "${no_review}" == "true" ]]; then echo "
※ レビューはスキップしてください。実装完了後、/exit で終了してください。"; else echo "
実装が完了したら、以下のループを実行してください：
1. /code-review スキルを実行してコードレビューを行う
2. 指摘事項がある場合は修正を実施する
3. 修正後、再度 /code-review を実行する
4. 指摘事項がなくなるまで 2-3 を繰り返す（最大3回）
5. レビュー結果（最終）を Write ツールで ${agent_dir}/review-result に書き込む
6. 完了したら /exit で終了する"; fi)

【質問がある場合】
- どうしても判断に迷う場合は、以下の手順で監督に確認してください：
  1. Write ツールで ${agent_dir}/question に質問内容を書き込む
  2. 数秒待ってから Read ツールで ${agent_dir}/answer を確認してください
  3. ファイルが存在しない場合は5秒待ってから再度確認してください（最大3回）
  4. 回答を読み取り、タスクを続行してください"

  # プロンプトファイル作成
  echo "$enhanced_prompt" > "${agent_dir}/enhanced_prompt"

  # 作業者ラッパースクリプトを作成
  local runner_script="${agent_dir}/runner.sh"
  cat > "$runner_script" <<RUNNER
#!/usr/bin/env bash
name="${name}"
agent_dir="${agent_dir}"
prompt_file="\${agent_dir}/enhanced_prompt"

echo "=== 作業者: \${name} ==="
echo "Dir: \$(pwd)"
echo "---"

# 対話モードで実行（実装→レビュー→修正ループをセッション内で完結）
claude --allowedTools "Edit,Write,Read,Grep,Glob,Bash,WebSearch,WebFetch" < "\${prompt_file}"

echo "completed" > "\${agent_dir}/status"
echo ""
echo "=== 完了 ==="
say "エージェント \${name} が完了しました"
RUNNER
  chmod +x "$runner_script"

  # 監督スクリプトを作成
  local supervisor_script="${agent_dir}/supervisor.sh"
  cat > "$supervisor_script" <<SUPERVISOR
#!/usr/bin/env bash
name="${name}"
agent_dir="${agent_dir}"
worker_pane_id_file="\${agent_dir}/worker-pane-id"
question_file="\${agent_dir}/question"
answer_file="\${agent_dir}/answer"

echo "=== 監督: \${name} ==="
echo "作業者の承認リクエストを監視中..."
echo ""

while true; do
  # 作業者ペインの生存確認
  if [[ -f "\${worker_pane_id_file}" ]]; then
    worker_pane=\$(cat "\${worker_pane_id_file}")
    if ! tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -q "^\${worker_pane}\\\$"; then
      echo ""
      echo "=== 作業者が終了しました ==="
      echo "completed" > "\${agent_dir}/status"
      break
    fi
  fi

  # レビュー結果の検出
  local review_file="\${agent_dir}/review-result"
  if [[ -f "\${review_file}" ]] && [[ ! -f "\${agent_dir}/review-notified" ]]; then
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📝 コードレビュー結果"
    echo ""
    cat "\${review_file}"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    touch "\${agent_dir}/review-notified"
  fi

  # 承認リクエストの検出
  if [[ -f "\${question_file}" ]] && [[ ! -f "\${answer_file}" ]]; then
    question_content=\$(cat "\${question_file}")
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📋 承認リクエスト検出"
    echo ""
    echo "\${question_content}"
    echo ""
    echo "判断中..."

    # claude -p で判断（エラー時は安全のため却下）
    answer=\$(claude -p "あなたは監督エージェントです。作業者からの以下の承認リクエストを判断してください。

リクエスト内容:
\${question_content}

判断基準:
- セキュリティ上の問題がないか
- 破壊的な操作ではないか
- タスクの目的に合致しているか

承認する場合は「承認: <簡潔な理由>」、却下する場合は「却下: <理由>」と回答してください。" 2>&1) || {
      echo "警告: 監督判断に失敗しました" >&2
      answer="却下: claude -p の実行に失敗しました。手動で確認してください"
    }

    # 回答を書き込み
    printf '%s' "\${answer}" > "\${answer_file}"
    echo "✅ 回答: \${answer}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # 10秒後にクリーンアップ（次の質問に備える）
    (sleep 10 && rm -f "\${question_file}" "\${answer_file}") &
  fi

  sleep 3
done

echo ""
say "監督 \${name} が終了しました"
read -r -p "Enterで閉じる..."
SUPERVISOR
  chmod +x "$supervisor_script"

  # 新しいウィンドウを作成して作業者を起動
  local window_name="${AGENT_PREFIX}${name}"
  local worker_pane_id
  worker_pane_id=$(tmux new-window -n "$window_name" -c "$work_dir" -P -F '#{pane_id}' "$runner_script")

  # 監督ペインを左側に追加（35%幅）
  local supervisor_pane_id
  supervisor_pane_id=$(tmux split-window -hb -l 35% -t "$worker_pane_id" -c "$work_dir" -P -F '#{pane_id}' "$supervisor_script")

  # メタデータ保存
  echo "$window_name" > "${agent_dir}/window-name"
  echo "$worker_pane_id" > "${agent_dir}/worker-pane-id"
  echo "$supervisor_pane_id" > "${agent_dir}/supervisor-pane-id"
  echo "running" > "${agent_dir}/status"

  echo "Agent '${name}' を起動しました"
  echo "  作業者ペイン: ${worker_pane_id}"
  echo "  監督ペイン:   ${supervisor_pane_id}"
  echo "  Dir: ${agent_dir}"
}

# supervise: 監督モード - 質問を検出して対話的に処理
cmd_supervise() {
  ensure_agents_dir

  echo "=== 監督モード: 質問待ちエージェントをチェック ==="
  echo ""

  local questions_found=0

  for agent_dir in "$AGENTS_DIR"/*/; do
    if [[ ! -d "$agent_dir" ]]; then
      continue
    fi

    local name=$(basename "$agent_dir")
    local question_file="${agent_dir}/question"
    local answer_file="${agent_dir}/answer"

    if [[ -f "$question_file" ]] && [[ ! -f "$answer_file" ]]; then
      questions_found=$((questions_found + 1))
      local question_content=$(cat "$question_file")

      echo "Agent: ${name}"
      echo "Question:"
      echo "${question_content}"
      echo "---"
    fi
  done

  if [[ $questions_found -eq 0 ]]; then
    echo "質問待ちのエージェントはありません"
    return 0
  fi

  echo ""
  echo "${questions_found} 件の質問があります。"
  echo ""
  echo "推奨: /supervise スキルを使用すると、自動的に判断して回答できます。"
}

# questions: 質問待ちエージェント一覧
cmd_questions() {
  ensure_agents_dir

  local found=0

  for agent_dir in "$AGENTS_DIR"/*/; do
    if [[ ! -d "$agent_dir" ]]; then
      continue
    fi

    local name=$(basename "$agent_dir")
    local question_file="${agent_dir}/question"
    local answer_file="${agent_dir}/answer"

    if [[ -f "$question_file" ]] && [[ ! -f "$answer_file" ]]; then
      found=1
      echo "=== Agent: ${name} ==="
      echo "質問:"
      cat "$question_file"
      echo ""
      echo "回答方法: claude-tmux answer ${name} \"回答内容\""
      echo ""
    fi
  done

  if [[ $found -eq 0 ]]; then
    echo "質問待ちのエージェントはありません"
  fi
}

# answer: 質問に回答
cmd_answer() {
  if [[ $# -lt 2 ]]; then
    echo "Error: エージェント名と回答を指定してください" >&2
    echo "Usage: claude-tmux answer <name> <回答>" >&2
    exit 1
  fi

  local name="$1"
  shift
  local answer="$*"

  local agent_dir="$(get_agent_dir "$name")"
  local question_file="${agent_dir}/question"
  local answer_file="${agent_dir}/answer"
  local worker_pane_file="${agent_dir}/worker-pane-id"

  if [[ ! -d "$agent_dir" ]]; then
    echo "Error: エージェント '${name}' が見つかりません" >&2
    exit 1
  fi

  if [[ ! -f "$question_file" ]]; then
    echo "Error: エージェント '${name}' には質問がありません" >&2
    exit 1
  fi

  # 回答をファイルに書き込み
  printf '%s' "$answer" > "$answer_file"
  echo "回答を ${answer_file} に書き込みました"

  # 作業者ペインが生きている場合、通知を送信
  if [[ -f "$worker_pane_file" ]]; then
    local worker_pane=$(cat "$worker_pane_file")
    if is_pane_alive "$worker_pane"; then
      tmux send-keys -t "$worker_pane" "" Enter
      echo "ペイン ${worker_pane} に通知を送信しました"
    else
      echo "Warning: 作業者ペインは既に終了しています"
    fi
  fi
}

# issues: 複数のGitHub Issueを並列エージェントで処理
cmd_issues() {
  require_tmux
  ensure_agents_dir

  if [[ $# -eq 0 ]]; then
    echo "Error: Issue番号を指定してください" >&2
    echo "Usage: claude-tmux issues 42 43 44" >&2
    exit 1
  fi

  for issue_num in "$@"; do
    local prompt="GitHub Issue #${issue_num} を gh issue view ${issue_num} で確認し、内容に基づいてタスクを遂行してください。"
    cmd_spawn "$prompt" --name "issue-${issue_num}"
  done
}

# status: 実行中のエージェント一覧とペイン生存確認
cmd_status() {
  ensure_agents_dir

  local count=0

  echo "=== エージェント一覧 ==="
  echo ""

  for agent_dir in "$AGENTS_DIR"/*/; do
    if [[ ! -d "$agent_dir" ]]; then
      continue
    fi

    local name=$(basename "$agent_dir")
    local worker_pane_file="${agent_dir}/worker-pane-id"
    local supervisor_pane_file="${agent_dir}/supervisor-pane-id"
    local status_file="${agent_dir}/status"
    local question_file="${agent_dir}/question"
    local answer_file="${agent_dir}/answer"

    count=$((count + 1))

    echo "  ${AGENT_PREFIX}${name}"

    # 作業者ペイン生存確認
    if [[ -f "$worker_pane_file" ]]; then
      local worker_pane=$(cat "$worker_pane_file")
      if is_pane_alive "$worker_pane"; then
        echo "    作業者: ${worker_pane} (alive)"
      else
        echo "    作業者: ${worker_pane} (dead)"
        echo "completed" > "$status_file"
      fi
    else
      echo "    作業者: unknown"
    fi

    # 監督ペイン生存確認
    if [[ -f "$supervisor_pane_file" ]]; then
      local supervisor_pane=$(cat "$supervisor_pane_file")
      if is_pane_alive "$supervisor_pane"; then
        echo "    監督:   ${supervisor_pane} (alive)"
      else
        echo "    監督:   ${supervisor_pane} (dead)"
      fi
    fi

    # ステータス
    if [[ -f "$status_file" ]]; then
      local status=$(cat "$status_file")
      echo "    Status: ${status}"
    fi

    # 質問・回答の状態
    if [[ -f "$question_file" ]] && [[ ! -f "$answer_file" ]]; then
      echo "    ⚠️  承認待ち"
    elif [[ -f "$answer_file" ]]; then
      echo "    ✓ 回答済み"
    fi

    echo "    Dir: ${agent_dir}"
    echo ""
  done

  if [[ $count -eq 0 ]]; then
    echo "エージェントはありません"
  fi
}

# clean: 完了/死亡したエージェントのディレクトリをクリーンアップ
cmd_clean() {
  ensure_agents_dir

  local cleaned=0

  for agent_dir in "$AGENTS_DIR"/*/; do
    if [[ ! -d "$agent_dir" ]]; then
      continue
    fi

    local name=$(basename "$agent_dir")
    local worker_pane_file="${agent_dir}/worker-pane-id"
    local should_clean=0

    if [[ -f "$worker_pane_file" ]]; then
      local worker_pane=$(cat "$worker_pane_file")
      if ! is_pane_alive "$worker_pane"; then
        should_clean=1
      fi
    else
      should_clean=1
    fi

    if [[ $should_clean -eq 1 ]]; then
      echo "クリーンアップ: ${name}"
      rm -rf "$agent_dir"
      cleaned=$((cleaned + 1))
    fi
  done

  if [[ $cleaned -eq 0 ]]; then
    echo "クリーンアップするエージェントはありません"
  else
    echo "${cleaned} 件のエージェントをクリーンアップしました"
  fi
}

# logs: 特定エージェントのログを less で表示
cmd_logs() {
  if [[ $# -eq 0 ]]; then
    echo "Error: エージェント名を指定してください" >&2
    echo "Usage: claude-tmux logs <name>" >&2
    exit 1
  fi

  local name="$1"
  local agent_dir="$(get_agent_dir "$name")"
  local log_file="${agent_dir}/log"

  if [[ ! -f "$log_file" ]]; then
    echo "Error: ログファイルが見つかりません: ${log_file}" >&2
    echo "Note: ログ機能は現在未実装です" >&2
    exit 1
  fi

  less +F "$log_file"
}

# kill: エージェントウィンドウ停止とディレクトリ削除
cmd_kill() {
  require_tmux

  if [[ $# -eq 0 ]]; then
    echo "Error: エージェント名または 'all' を指定してください" >&2
    echo "Usage: claude-tmux kill [name|all]" >&2
    exit 1
  fi

  local target="$1"

  if [[ "$target" == "all" ]]; then
    for agent_dir in "$AGENTS_DIR"/*/; do
      if [[ ! -d "$agent_dir" ]]; then
        continue
      fi

      local name=$(basename "$agent_dir")
      kill_agent_window "$agent_dir" "$name"
      rm -rf "$agent_dir"
    done
  else
    local agent_dir="$(get_agent_dir "$target")"

    if [[ ! -d "$agent_dir" ]]; then
      echo "Error: エージェント '${target}' が見つかりません" >&2
      exit 1
    fi

    kill_agent_window "$agent_dir" "$target"
    rm -rf "$agent_dir"
    echo "削除: ${agent_dir}"
  fi
}

# ウィンドウ単位でエージェントを停止するヘルパー
kill_agent_window() {
  local agent_dir="$1"
  local name="$2"
  local window_name_file="${agent_dir}/window-name"

  # ウィンドウ名でkill（両ペインまとめて停止）
  if [[ -f "$window_name_file" ]]; then
    local window_name=$(cat "$window_name_file")
    if tmux list-windows -F '#{window_name}' 2>/dev/null | grep -q "^${window_name}$"; then
      tmux kill-window -t "=${window_name}" 2>/dev/null || true
      echo "停止: ${name} (window: ${window_name})"
      return
    fi
  fi

  # フォールバック: 個別ペインをkill
  for pane_file in "${agent_dir}/worker-pane-id" "${agent_dir}/supervisor-pane-id"; do
    if [[ -f "$pane_file" ]]; then
      local pane_id=$(cat "$pane_file")
      if is_pane_alive "$pane_id"; then
        tmux kill-pane -t "$pane_id" 2>/dev/null || true
      fi
    fi
  done
  echo "停止: ${name}"
}

# メインルーティング
case "${1:-}" in
  spawn)
    shift
    cmd_spawn "$@"
    ;;
  issues)
    shift
    cmd_issues "$@"
    ;;
  status)
    cmd_status
    ;;
  supervise)
    cmd_supervise
    ;;
  questions)
    cmd_questions
    ;;
  answer)
    shift
    cmd_answer "$@"
    ;;
  logs)
    shift
    cmd_logs "$@"
    ;;
  kill)
    shift
    cmd_kill "$@"
    ;;
  clean)
    cmd_clean
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    echo "Error: 不明なサブコマンド '$1'" >&2
    usage
    exit 1
    ;;
esac
