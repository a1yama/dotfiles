#!/usr/bin/env bash
set -euo pipefail

AGENT_PREFIX="🤖"
AGENTS_DIR="/tmp/claude-agents"
SKILL_DIR="$HOME/.claude/skills/code-review"

usage() {
  cat <<'EOF'
claude-tmux - tmux × Claude Code 並列エージェント管理（オーケストレーション対応）

Usage:
  claude-tmux spawn "タスク説明"  [--name NAME] [--dir DIR] [--no-review]
  claude-tmux issues 42 43 44
  claude-tmux status
  claude-tmux supervise
  claude-tmux questions
  claude-tmux answer <name> <回答>
  claude-tmux logs <name>
  claude-tmux kill [name|all]
  claude-tmux clean

Subcommands:
  spawn      新しいtmuxペインでインタラクティブエージェントを起動（実装後に自動レビュー）
  issues     複数のGitHub Issueを並列エージェントで処理
  status     実行中のエージェント一覧とペイン生存確認
  supervise  監督モード：質問待ちエージェントを検出して対話的に回答（推奨）
  questions  質問待ちのエージェント一覧を表示（デバッグ用）
  answer     質問に回答（answerファイル作成 + ペインに通知）（デバッグ用）
  logs       特定エージェントのログを less で表示
  kill       エージェントペイン停止とディレクトリ削除
  clean      完了/死亡したエージェントのディレクトリをクリーンアップ

Note:
  エージェントはインタラクティブモードでペイン分割実行されます。
  質問は監督モード (supervise) が自動的に検出して処理します。
  意図しないファイル変更のリスクがあるため、実行後に git diff で変更内容を確認してください。
EOF
}

require_tmux() {
  if [[ -z "${TMUX:-}" ]]; then
    echo "Error: tmuxセッション内で実行してください" >&2
    exit 1
  fi
}

ensure_agents_dir() {
  mkdir -p "$AGENTS_DIR"
}

get_agent_dir() {
  local name="$1"
  echo "${AGENTS_DIR}/${name}"
}

is_pane_alive() {
  local pane_id="$1"
  tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -q "^${pane_id}$"
}

# spawn: 新しいtmuxペインでインタラクティブエージェントを起動
cmd_spawn() {
  require_tmux
  ensure_agents_dir

  local name=""
  local dir=""
  local prompt=""
  local no_review="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        name="$2"
        shift 2
        ;;
      --dir)
        dir="$2"
        shift 2
        ;;
      --no-review)
        no_review="true"
        shift
        ;;
      *)
        if [[ -z "$prompt" ]]; then
          prompt="$1"
        else
          prompt="$prompt $1"
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$prompt" ]]; then
    echo "Error: タスク説明を指定してください" >&2
    echo "Usage: claude-tmux spawn \"タスク説明\" [--name NAME] [--dir DIR]" >&2
    exit 1
  fi

  if [[ -z "$name" ]]; then
    name="agent-$(date +%s)"
  fi

  local work_dir="${dir:-$(pwd)}"
  local agent_dir="$(get_agent_dir "$name")"

  # エージェントディレクトリ作成
  mkdir -p "$agent_dir"

  # プロンプトファイル作成
  local prompt_file="${agent_dir}/prompt"
  printf '%s' "$prompt" > "$prompt_file"

  # 拡張プロンプト作成
  local enhanced_prompt="${prompt}

---

【重要】自律的な実装について：

このタスクは自動実行モードで実行されています。以下のルールに従ってください：
- ユーザーに質問せず、最善の判断で実装を進めてください
- 技術選択が必要な場合は、一般的でメンテナンス性の高い選択を優先してください
- セキュリティとシンプルさを重視してください

【ツール使用の制限】
- Bashツールの使用は極力避けてください
- ファイルの読み取りはReadツール、検索はGrepツールを優先してください
- どうしてもBashが必要な場合は、以下の手順で監督に確認してください：
  1. Write ツールで ${agent_dir}/question に「Bashコマンド実行の承認: <コマンド内容>」を書き込む
  2. 監督が ${agent_dir}/answer に回答を書き込むまで待機
  3. Read ツールで ${agent_dir}/answer から回答を読み取り、承認されたら実行"

  # プロンプトファイル作成
  echo "$enhanced_prompt" > "${agent_dir}/enhanced_prompt"

  # ラッパースクリプトを作成
  local runner_script="${agent_dir}/runner.sh"
  cat > "$runner_script" <<RUNNER
#!/usr/bin/env bash
name="${name}"
agent_dir="${agent_dir}"
prompt_file="\${agent_dir}/enhanced_prompt"
log_file="\${agent_dir}/log"

echo "=== Claude Agent: \${name} ==="
echo "Dir: \$(pwd)"
echo "---"

# 過程を表示しながら実行（Edit/Write/Read自動承認）
claude --allowedTools "Edit Write Read" < "\${prompt_file}"

echo ""
echo "=== 実装完了 ==="

# 自動コードレビュー（--no-reviewでスキップ）
if [[ "${no_review}" != "true" ]]; then
  changes=\$(git status --short 2>/dev/null || true)
  if [[ -n "\${changes}" ]]; then
    echo "=== コードレビュー開始 ==="
    echo "/code-review" | claude
    echo "=== レビュー完了 ==="
  else
    echo "変更なし — レビューをスキップ"
  fi
fi

echo ""
echo "=== 完了 ==="
say "エージェント \${name} が完了しました"
read -r -p "Enterで閉じる..."
RUNNER
  chmod +x "$runner_script"

  # 新しいウィンドウを作成してラッパースクリプトを実行
  local window_name="${AGENT_PREFIX}${name}"
  tmux new-window -n "$window_name" -c "$work_dir" "$runner_script"

  # window nameを保存
  echo "$window_name" > "${agent_dir}/window-name"

  # statusファイル作成
  echo "running" > "${agent_dir}/status"

  echo "Agent '${name}' を起動しました (pane: ${pane_id})"
  echo "Dir: ${agent_dir}"
  echo ""
  echo "監督: /supervise"
}

# supervise: 監督モード - 質問を検出して対話的に処理
cmd_supervise() {
  ensure_agents_dir

  echo "=== 監督モード: 質問待ちエージェントをチェック ==="
  echo ""

  local questions_found=0

  for agent_dir in "$AGENTS_DIR"/*/; do
    if [[ ! -d "$agent_dir" ]]; then
      continue
    fi

    local name=$(basename "$agent_dir")
    local question_file="${agent_dir}question"
    local answer_file="${agent_dir}answer"

    if [[ -f "$question_file" ]] && [[ ! -f "$answer_file" ]]; then
      questions_found=$((questions_found + 1))
      local question_content=$(cat "$question_file")

      echo "Agent: ${name}"
      echo "Question:"
      echo "${question_content}"
      echo "---"
    fi
  done

  if [[ $questions_found -eq 0 ]]; then
    echo "質問待ちのエージェントはありません"
    return 0
  fi

  echo ""
  echo "${questions_found} 件の質問があります。"
  echo ""
  echo "推奨: /supervise スキルを使用すると、自動的に判断して回答できます。"
}

# questions: 質問待ちエージェント一覧
cmd_questions() {
  ensure_agents_dir

  local found=0

  for agent_dir in "$AGENTS_DIR"/*/; do
    if [[ ! -d "$agent_dir" ]]; then
      continue
    fi

    local name=$(basename "$agent_dir")
    local question_file="${agent_dir}question"
    local answer_file="${agent_dir}answer"

    if [[ -f "$question_file" ]] && [[ ! -f "$answer_file" ]]; then
      found=1
      echo "=== Agent: ${name} ==="
      echo "質問:"
      cat "$question_file"
      echo ""
      echo "回答方法: claude-tmux answer ${name} \"回答内容\""
      echo ""
    fi
  done

  if [[ $found -eq 0 ]]; then
    echo "質問待ちのエージェントはありません"
  fi
}

# answer: 質問に回答
cmd_answer() {
  if [[ $# -lt 2 ]]; then
    echo "Error: エージェント名と回答を指定してください" >&2
    echo "Usage: claude-tmux answer <name> <回答>" >&2
    exit 1
  fi

  local name="$1"
  shift
  local answer="$*"

  local agent_dir="$(get_agent_dir "$name")"
  local question_file="${agent_dir}/question"
  local answer_file="${agent_dir}/answer"
  local pane_id_file="${agent_dir}/pane-id"

  if [[ ! -d "$agent_dir" ]]; then
    echo "Error: エージェント '${name}' が見つかりません" >&2
    exit 1
  fi

  if [[ ! -f "$question_file" ]]; then
    echo "Error: エージェント '${name}' には質問がありません" >&2
    exit 1
  fi

  # 回答をファイルに書き込み
  printf '%s' "$answer" > "$answer_file"
  echo "回答を ${answer_file} に書き込みました"

  # ペインが生きている場合、通知を送信
  if [[ -f "$pane_id_file" ]]; then
    local pane_id=$(cat "$pane_id_file")
    if is_pane_alive "$pane_id"; then
      tmux send-keys -t "$pane_id" "" Enter
      echo "ペイン ${pane_id} に通知を送信しました"
    else
      echo "Warning: ペインは既に終了しています"
    fi
  fi
}

# issues: 複数のGitHub Issueを並列エージェントで処理
cmd_issues() {
  require_tmux
  ensure_agents_dir

  if [[ $# -eq 0 ]]; then
    echo "Error: Issue番号を指定してください" >&2
    echo "Usage: claude-tmux issues 42 43 44" >&2
    exit 1
  fi

  for issue_num in "$@"; do
    local prompt="GitHub Issue #${issue_num} を gh issue view ${issue_num} で確認し、内容に基づいてタスクを遂行してください。"
    cmd_spawn "$prompt" --name "issue-${issue_num}"
  done
}

# status: 実行中のエージェント一覧とペイン生存確認
cmd_status() {
  ensure_agents_dir

  local count=0

  echo "=== エージェント一覧 ==="
  echo ""

  for agent_dir in "$AGENTS_DIR"/*/; do
    if [[ ! -d "$agent_dir" ]]; then
      continue
    fi

    local name=$(basename "$agent_dir")
    local pane_id_file="${agent_dir}/pane-id"
    local status_file="${agent_dir}/status"
    local question_file="${agent_dir}/question"
    local answer_file="${agent_dir}/answer"

    count=$((count + 1))

    echo "  ${AGENT_PREFIX}${name}"

    # ペイン生存確認
    if [[ -f "$pane_id_file" ]]; then
      local pane_id=$(cat "$pane_id_file")
      if is_pane_alive "$pane_id"; then
        echo "    Pane: ${pane_id} (alive)"
      else
        echo "    Pane: ${pane_id} (dead)"
        echo "completed" > "$status_file"
      fi
    else
      echo "    Pane: unknown"
    fi

    # ステータス
    if [[ -f "$status_file" ]]; then
      local status=$(cat "$status_file")
      echo "    Status: ${status}"
    fi

    # 質問・回答の状態
    if [[ -f "$question_file" ]] && [[ ! -f "$answer_file" ]]; then
      echo "    ⚠️  質問待ち - '/supervise' で自動回答"
    elif [[ -f "$answer_file" ]]; then
      echo "    ✓ 回答済み"
    fi

    echo "    Dir: ${agent_dir}"
    echo ""
  done

  if [[ $count -eq 0 ]]; then
    echo "エージェントはありません"
  fi
}

# clean: 完了/死亡したエージェントのディレクトリをクリーンアップ
cmd_clean() {
  ensure_agents_dir

  local cleaned=0

  for agent_dir in "$AGENTS_DIR"/*/; do
    if [[ ! -d "$agent_dir" ]]; then
      continue
    fi

    local name=$(basename "$agent_dir")
    local pane_id_file="${agent_dir}/pane-id"
    local should_clean=0

    if [[ -f "$pane_id_file" ]]; then
      local pane_id=$(cat "$pane_id_file")
      if ! is_pane_alive "$pane_id"; then
        should_clean=1
      fi
    else
      should_clean=1
    fi

    if [[ $should_clean -eq 1 ]]; then
      echo "クリーンアップ: ${name}"
      rm -rf "$agent_dir"
      cleaned=$((cleaned + 1))
    fi
  done

  if [[ $cleaned -eq 0 ]]; then
    echo "クリーンアップするエージェントはありません"
  else
    echo "${cleaned} 件のエージェントをクリーンアップしました"
  fi
}

# logs: 特定エージェントのログを less で表示
cmd_logs() {
  if [[ $# -eq 0 ]]; then
    echo "Error: エージェント名を指定してください" >&2
    echo "Usage: claude-tmux logs <name>" >&2
    exit 1
  fi

  local name="$1"
  local agent_dir="$(get_agent_dir "$name")"
  local log_file="${agent_dir}/log"

  if [[ ! -f "$log_file" ]]; then
    echo "Error: ログファイルが見つかりません: ${log_file}" >&2
    echo "Note: ログ機能は現在未実装です" >&2
    exit 1
  fi

  less +F "$log_file"
}

# kill: エージェントペイン停止とディレクトリ削除
cmd_kill() {
  require_tmux

  if [[ $# -eq 0 ]]; then
    echo "Error: エージェント名または 'all' を指定してください" >&2
    echo "Usage: claude-tmux kill [name|all]" >&2
    exit 1
  fi

  local target="$1"

  if [[ "$target" == "all" ]]; then
    for agent_dir in "$AGENTS_DIR"/*/; do
      if [[ ! -d "$agent_dir" ]]; then
        continue
      fi

      local name=$(basename "$agent_dir")
      local pane_id_file="${agent_dir}/pane-id"

      if [[ -f "$pane_id_file" ]]; then
        local pane_id=$(cat "$pane_id_file")
        if is_pane_alive "$pane_id"; then
          tmux kill-pane -t "$pane_id" 2>/dev/null || true
          echo "停止: ${name} (${pane_id})"
        fi
      fi

      rm -rf "$agent_dir"
    done
  else
    local agent_dir="$(get_agent_dir "$target")"
    local pane_id_file="${agent_dir}/pane-id"

    if [[ ! -d "$agent_dir" ]]; then
      echo "Error: エージェント '${target}' が見つかりません" >&2
      exit 1
    fi

    if [[ -f "$pane_id_file" ]]; then
      local pane_id=$(cat "$pane_id_file")
      if is_pane_alive "$pane_id"; then
        tmux kill-pane -t "$pane_id" 2>/dev/null || true
        echo "停止: ${target} (${pane_id})"
      else
        echo "Warning: ペインは既に終了しています"
      fi
    fi

    rm -rf "$agent_dir"
    echo "削除: ${agent_dir}"
  fi
}

# メインルーティング
case "${1:-}" in
  spawn)
    shift
    cmd_spawn "$@"
    ;;
  issues)
    shift
    cmd_issues "$@"
    ;;
  status)
    cmd_status
    ;;
  supervise)
    cmd_supervise
    ;;
  questions)
    cmd_questions
    ;;
  answer)
    shift
    cmd_answer "$@"
    ;;
  logs)
    shift
    cmd_logs "$@"
    ;;
  kill)
    shift
    cmd_kill "$@"
    ;;
  clean)
    cmd_clean
    ;;
  -h|--help|"")
    usage
    ;;
  *)
    echo "Error: 不明なサブコマンド '$1'" >&2
    usage
    exit 1
    ;;
esac
