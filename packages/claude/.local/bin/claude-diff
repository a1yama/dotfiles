.cbox .row{display:flex;gap:6px;margin-top:6px}
.cmt{margin:4px 8px;padding:6px 10px;border-left:3px solid var(--accent);background:#161b22;border-radius:0 6px 6px 0}
.cmt .meta{color:var(--mut);font-size:11px}
.badge{font-size:10px;padding:1px 6px;border-radius:10px;margin-left:6px}
.b-pending{background:#9e6a03;color:#fff}.b-delivered{background:#1f6feb;color:#fff}.b-resolved{background:#238636;color:#fff}
.empty{color:var(--mut);padding:30px;text-align:center}
</style></head>
<body>
<header>
<h1>claude-diff</h1>
<select id="range">
<option value="uncommitted">未コミット差分 (git diff HEAD)</option>
<option value="branch">ブランチ全体 (base..HEAD)</option>
</select>
<input id="custom" placeholder="任意: HEAD~3 / a..b" style="background:#21262d;color:var(--fg);border:1px solid var(--bd);border-radius:6px;padding:4px 8px;font:inherit;width:160px">
<button onclick="load()">更新</button>
<label class="stat"><input type="checkbox" id="auto" checked> 自動更新</label>
<span class="spacer"></span>
<span class="stat" id="stat"></span>
</header>
<div id="diff"></div>
<script>
let comments=[];
function key(f,l,s){return f+'@'+l+'@'+s}
async function load(){
  let r=document.getElementById('custom').value.trim()||document.getElementById('range').value;
  const res=await fetch('/api/diff?range='+encodeURIComponent(r));
  const data=await res.json();
  comments=data.comments;
  render(data.files);
  stat();
}
async function refreshComments(){
  const res=await fetch('/api/comments');comments=await res.json();
  document.querySelectorAll('[data-anchor]').forEach(el=>{el.innerHTML=cmtHtml(el.dataset.anchor)});
  stat();
}
function stat(){
  const c={pending:0,delivered:0,resolved:0};comments.forEach(x=>c[x.status]++);
  document.getElementById('stat').textContent=`pending ${c.pending} / delivered ${c.delivered} / resolved ${c.resolved}`;
}
function cmtHtml(anchor){
  return comments.filter(c=>key(c.file,c.line,c.side)===anchor).map(c=>
    `<div class="cmt"><div class="meta">${c.ts}<span class="badge b-${c.status}">${c.status}</span></div>${esc(c.comment)}</div>`).join('');
}
function esc(s){return (s||'').replace(/[&<>]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[m]))}
function render(files){
  const root=document.getElementById('diff');root.innerHTML='';
  if(!files.length){root.innerHTML='<div class="empty">差分はありません</div>';return}
  for(const f of files){
    const div=document.createElement('div');div.className='file';
    let rows='';
    for(const h of f.hunks){
      rows+=`<tr class="hh"><td class="ln"></td><td class="ln"></td><td class="gut"></td><td class="code">${esc(h.header)}</td></tr>`;
      for(const ln of h.lines){
        const cls=ln.type==='add'?'add':ln.type==='del'?'del':'';
        const lno=ln.new!=null?ln.new:(ln.old!=null?ln.old:'');
        const side=ln.type==='del'?'old':'new';
        const anc=key(f.path,lno,side);
        rows+=`<tr class="${cls}"><td class="ln">${ln.old??''}</td><td class="ln">${ln.new??''}</td>`+
          `<td class="gut" onclick="openBox('${f.path}',${lno||'null'},'${side}',this)">+</td>`+
          `<td class="code">${esc(ln.text)}</td></tr>`+
          `<tr><td colspan="2"></td><td></td><td><div data-anchor="${anc}">${cmtHtml(anc)}</div></td></tr>`;
      }
    }
    div.innerHTML=`<div class="fh">${esc(f.path)}</div><table>${rows}</table>`;
    root.appendChild(div);
  }
}
function openBox(file,line,side,gut){
  const tr=gut.closest('tr');
  if(tr.nextSibling&&tr.nextSibling.querySelector&&tr.nextSibling.querySelector('.cbox'))return;
  const box=document.createElement('tr');
  box.innerHTML=`<td colspan="2"></td><td></td><td><div class="cbox">
    <textarea placeholder="この行へのフィードバック…"></textarea>
    <div class="row"><button>送信</button><button class="cancel">取消</button></div></div></td>`;
  tr.after(box);
  const ta=box.querySelector('textarea');ta.focus();
  box.querySelector('button').onclick=async()=>{
    const v=ta.value.trim();if(!v)return;
    await fetch('/api/comment',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({file,line,side,comment:v})});
    box.remove();refreshComments();
  };
  box.querySelector('.cancel').onclick=()=>box.remove();
}
setInterval(()=>{if(document.getElementById('auto').checked&&!document.querySelector('.cbox'))refreshComments()},3000);
load();
</script></body></html>
"""


class Handler(http.server.BaseHTTPRequestHandler):
    root = None
    fb = None

    def log_message(self, *a):
        pass

    def _json(self, obj, code=200):
        body = json.dumps(obj, ensure_ascii=False).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        u = urlparse(self.path)
        if u.path == "/":
            body = PAGE.encode()
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        elif u.path == "/api/diff":
            rng = parse_qs(u.query).get("range", ["uncommitted"])[0]
            files = parse_diff(get_diff_text(self.root, rng))
            self._json({"files": files, "comments": read_feedback(self.fb)})
        elif u.path == "/api/comments":
            self._json(read_feedback(self.fb))
        else:
            self.send_error(404)

    def do_POST(self):
        if urlparse(self.path).path != "/api/comment":
            return self.send_error(404)
        ln = int(self.headers.get("Content-Length", 0))
        data = json.loads(self.rfile.read(ln) or b"{}")
        item = {
            "id": hashlib.sha1(
                f"{data.get('file')}{data.get('line')}{time.time()}".encode()
            ).hexdigest()[:8],
            "ts": time.strftime("%Y-%m-%d %H:%M"),
            "file": data.get("file", ""),
            "line": data.get("line"),
            "side": data.get("side", "new"),
            "comment": data.get("comment", ""),
            "status": "pending",
        }
        with FileLock(self.fb):
            items = read_feedback(self.fb)
            items.append(item)
            write_feedback(self.fb, items)
        self._json({"ok": True, "id": item["id"]})


def cmd_serve(args):
    root = repo_root()
    Handler.root = root
    Handler.fb = feedback_path(root)
    httpd = http.server.ThreadingHTTPServer(("127.0.0.1", args.port), Handler)
    url = f"http://127.0.0.1:{args.port}/"
    print(f"claude-diff serving {root}\n  {url}\n  feedback: {Handler.fb}")
    if not args.no_open:
        webbrowser.open(url)
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        pass


def cmd_watch(args):
    root = repo_root()
    fb = feedback_path(root)
    deadline = time.time() + args.timeout
    while time.time() < deadline:
        with FileLock(fb):
            items = read_feedback(fb)
            pending = [x for x in items if x["status"] == "pending"]
            if pending:
                for x in items:
                    if x["status"] == "pending":
                        x["status"] = "delivered"
                write_feedback(fb, items)
        if pending:
            print(f"=== 新しいフィードバック {len(pending)}件 ===")
            for x in pending:
                loc = f"{x['file']}:{x['line']}" if x["line"] else x["file"]
                print(f"[{x['id']}] {loc}\n  {x['comment']}")
            print("\n対応したら `claude-diff resolve <id>` で resolved にしてください。")
            return
        time.sleep(args.interval)
    print("TIMEOUT: フィードバックはありませんでした")


def cmd_resolve(args):
    root = repo_root()
    fb = feedback_path(root)
    with FileLock(fb):
        items = read_feedback(fb)
        ids = set(args.ids)
        n = 0
        for x in items:
            if x["id"] in ids or "all" in ids:
                x["status"] = "resolved"
                n += 1
        write_feedback(fb, items)
    print(f"{n}件を resolved にしました")


def cmd_status(args):
    root = repo_root()
    items = read_feedback(feedback_path(root))
    c = {"pending": 0, "delivered": 0, "resolved": 0}
    for x in items:
        c[x["status"]] = c.get(x["status"], 0) + 1
    print(f"pending {c['pending']} / delivered {c['delivered']} / resolved {c['resolved']}")
    for x in items:
        if x["status"] != "resolved":
            loc = f"{x['file']}:{x['line']}" if x["line"] else x["file"]
            print(f"  [{x['id']}] {x['status']:9} {loc}  {x['comment'][:60]}")


def cmd_tmux(args):
    """別ペインに色付き git diff を定期更新で表示（軽量ビューア=B案）。"""
    root = repo_root()
    pager = "delta --paging=never" if subprocess.run(
        ["which", "delta"], capture_output=True
    ).returncode == 0 else "less -R"
    rng = args.range if args.range != "uncommitted" else "HEAD"
    inner = (
        f"cd {root}; while true; do clear; "
        f"git -c color.ui=always diff {rng} | {pager}; "
        f"echo '--- {args.interval}s毎に更新 (Ctrl-C で終了) ---'; sleep {args.interval}; done"
    )
    if subprocess.run(["which", "tmux"], capture_output=True).returncode != 0:
        sys.exit("tmux が見つかりません")
    if os.environ.get("TMUX"):
        subprocess.run(["tmux", "split-window", "-h", inner])
    else:
        subprocess.run(["tmux", "new-session", "-d", "-s", "claude-diff", inner])
        print("tmux セッション 'claude-diff' を作成しました: tmux attach -t claude-diff")


def main():
    p = argparse.ArgumentParser(description="claude-diff")
    sub = p.add_subparsers(dest="cmd", required=True)

    s = sub.add_parser("serve")
    s.add_argument("--port", type=int, default=4517)
    s.add_argument("--no-open", action="store_true")
    s.set_defaults(func=cmd_serve)

    w = sub.add_parser("watch")
    w.add_argument("--timeout", type=int, default=1800)
    w.add_argument("--interval", type=int, default=2)
    w.set_defaults(func=cmd_watch)

    r = sub.add_parser("resolve")
    r.add_argument("ids", nargs="+")
    r.set_defaults(func=cmd_resolve)

    st = sub.add_parser("status")
    st.set_defaults(func=cmd_status)

    t = sub.add_parser("tmux")
    t.add_argument("--range", default="uncommitted")
    t.add_argument("--interval", type=int, default=3)
    t.set_defaults(func=cmd_tmux)

    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
