#!/usr/bin/env python3
"""claude-diff - Claudeを閉じずにブラウザで差分を見て、行コメントでフィードバックを返す。

サブコマンド:
  serve   差分ビューアのローカルWebサーバを起動（フォアグラウンド）
  watch   フィードバックファイルに新規コメントが入るまでブロックし、入ったら出力して終了
  resolve 指定IDのコメントを resolved にする
  status  pending / delivered / resolved の件数を表示
  tmux    別tmuxペインに色付き git diff を定期更新表示（軽量ビューア）

フィードバックはリポジトリを汚さないよう ~/.local/state/claude-diff/<repo-hash>/feedback.jsonl に保存する。
"""
import argparse
import fcntl
import hashlib
import http.server
import json
import os
import subprocess
import sys
import time
import webbrowser
from html import escape
from pathlib import Path
from urllib.parse import urlparse, parse_qs


def run_git(args, cwd=None):
    return subprocess.run(
        ["git", *args], cwd=cwd, capture_output=True, text=True
    )


def repo_root(cwd=None):
    r = run_git(["rev-parse", "--show-toplevel"], cwd=cwd)
    if r.returncode != 0:
        sys.exit("git リポジトリ内で実行してください")
    return r.stdout.strip()


def state_dir(root):
    key = hashlib.sha1(root.encode()).hexdigest()[:12]
    d = Path.home() / ".local/state/claude-diff" / key
    d.mkdir(parents=True, exist_ok=True)
    return d


def feedback_path(root):
    return state_dir(root) / "feedback.jsonl"


def read_feedback(path):
    if not path.exists():
        return []
    items = []
    with open(path) as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    items.append(json.loads(line))
                except json.JSONDecodeError:
                    pass
    return items


def write_feedback(path, items):
    tmp = path.with_suffix(".tmp")
    with open(tmp, "w") as f:
        for it in items:
            f.write(json.dumps(it, ensure_ascii=False) + "\n")
    tmp.replace(path)


class FileLock:
    def __init__(self, path):
        self.lockfile = Path(str(path) + ".lock")

    def __enter__(self):
        self.fh = open(self.lockfile, "w")
        fcntl.flock(self.fh, fcntl.LOCK_EX)
        return self

    def __exit__(self, *a):
        fcntl.flock(self.fh, fcntl.LOCK_UN)
        self.fh.close()


# ---- 差分の取得とパース --------------------------------------------------

def base_ref(root):
    """ブランチ全体差分のベースを推定する。"""
    for cand in ["origin/main", "origin/master", "main", "master"]:
        if run_git(["rev-parse", "--verify", "--quiet", cand], cwd=root).returncode == 0:
            mb = run_git(["merge-base", "HEAD", cand], cwd=root)
            if mb.returncode == 0 and mb.stdout.strip():
                return mb.stdout.strip(), cand
    return None, None


def get_diff_text(root, rng):
    """rng: 'uncommitted' | 'branch' | 任意の git diff 引数文字列。"""
    if rng == "uncommitted":
        out = run_git(["diff", "HEAD"], cwd=root).stdout
        # 未追跡ファイルを新規追加として合成
        untracked = run_git(
            ["ls-files", "--others", "--exclude-standard"], cwd=root
        ).stdout.split()
        for fp in untracked:
            d = run_git(["diff", "--no-index", "--", "/dev/null", fp], cwd=root)
            out += d.stdout
        return out
    if rng == "branch":
        mb, name = base_ref(root)
        if not mb:
            return run_git(["diff", "HEAD"], cwd=root).stdout
        return run_git(["diff", f"{mb}", "HEAD"], cwd=root).stdout
    # 任意指定（例: "abc123..def456" や "HEAD~3"）
    return run_git(["diff", *rng.split()], cwd=root).stdout


def parse_diff(text):
    """unified diff を {path, hunks:[{header, lines:[{type, old, new, text}]}]} の配列に。"""
    files = []
    cur = None
    old_no = new_no = 0
    for line in text.splitlines():
        if line.startswith("diff --git"):
            cur = {"path": "", "hunks": []}
            files.append(cur)
        elif line.startswith("+++ "):
            p = line[4:]
            if p.startswith("b/"):
                p = p[2:]
            if cur is not None and p != "/dev/null":
                cur["path"] = p
        elif line.startswith("--- "):
            if cur is not None and not cur["path"]:
                p = line[4:]
                if p.startswith("a/"):
                    p = p[2:]
                if p != "/dev/null":
                    cur["path"] = p
        elif line.startswith("@@"):
            # @@ -old,cnt +new,cnt @@
            try:
                seg = line.split("@@")[1].strip()
                old_part, new_part = seg.split(" ")
                old_no = int(old_part[1:].split(",")[0])
                new_no = int(new_part[1:].split(",")[0])
            except (IndexError, ValueError):
                old_no = new_no = 0
            if cur is not None:
                cur["hunks"].append({"header": line, "lines": []})
        elif cur is not None and cur["hunks"]:
            hunk = cur["hunks"][-1]
            if line.startswith("+"):
                hunk["lines"].append({"type": "add", "old": None, "new": new_no, "text": line[1:]})
                new_no += 1
            elif line.startswith("-"):
                hunk["lines"].append({"type": "del", "old": old_no, "new": None, "text": line[1:]})
                old_no += 1
            elif line.startswith("\\"):
                continue  # \ No newline at end of file
            else:
                hunk["lines"].append({"type": "ctx", "old": old_no, "new": new_no, "text": line[1:]})
                old_no += 1
                new_no += 1
    return [f for f in files if f["path"]]


# ---- HTMLレンダリング ----------------------------------------------------

PAGE = """<!DOCTYPE html>
